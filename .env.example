# ============================================
# PTA V2 - Environment Variables
# Copy to .env on the VM and fill in. Never commit the real .env.
# ============================================

# --- Dhan Broker API Credentials ---
# https://web.dhan.co -> My Profile -> Access DhanHQ APIs
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_PIN=your_6_digit_pin
# TOTP "Setup key" for automatic token generation
DHAN_TOTP_SECRET=YOUR_TOTP_SECRET_HERE
# OR a manual token (expires daily; not recommended)
# DHAN_ACCESS_TOKEN=your_manual_token

# --- Postgres (system of record) ---
# docker-compose builds DATABASE_URL from these three:
POSTGRES_USER=pta
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=pta
# If running the app outside compose, set the full URL instead:
# DATABASE_URL=postgres://pta:password@host:5432/pta

# --- Redis (ephemeral live state) ---
# Inside compose this is redis://redis:6379
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=pta:

# --- Server ---
PORT=3000

# Local dry-run without Dhan/Postgres
USE_MOCK=false
