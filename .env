# ============================================
# PTA - Railway Deployment Environment Variables
# ============================================

# Dhan Broker API Credentials
# Get these from https://web.dhan.co -> My Profile -> Access DhanHQ APIs
DHAN_CLIENT_ID=1100222418
DHAN_PIN=180893

# TOTP Secret (for automatic token generation every 20 hours)
# Get this when you setup TOTP on Dhan Web. Copy the "Setup key" text.
DHAN_TOTP_SECRET=UE3QO6UCFLCTXSINTHVRETM6OG4IR6NV

# OR: Manual Access Token (expires every 24 hours, not recommended for Railway)
# DHAN_ACCESS_TOKEN=your_manual_token

# Redis URL - Railway will provide this automatically when you add Redis service
# Format: redis://default:password@host:port
REDIS_URL=redis://localhost:6379

# SQLite Path (Railway uses ephemeral storage by default)
# For persistent storage on Railway, use /mnt/data/pta_archive.db
SQLITE_PATH=./pta_archive.db

# Server Port - Railway sets this automatically
PORT=3000

# Use Mock Provider for testing (no real market data needed)
USE_MOCK=false

# Optional: Redis key prefix if sharing Redis instance
REDIS_PREFIX=pta:
