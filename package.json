{
  "name": "pta-personal-trading-assistant",
  "version": "1.0.0",
  "description": "Real-time event-driven market intelligence engine for intraday options trading",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:mock": "USE_MOCK=true node server.js",
    "dev": "nodemon server.js",
    "build:engine": "tsc -p engine",
    "build": "npm run build:engine && cd frontend && npm install && npm run build",
    "production": "npm run build && npm start",
    "test": "jest --coverage",
    "test:engine": "npm run build:engine && node --test engine/test",
    "test:server": "node --test test"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.5.0",
    "express": "^4.19.0",
    "pg": "^8.21.0",
    "redis": "^4.6.0",
    "totp-generator": "^1.0.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
